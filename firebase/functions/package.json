{
  "name": "codex-remote-functions",
  "version": "0.1.0",
  "private": true,
  "description": "Firebase Cloud Functions for Codex Remote Android.",
  "type": "module",
  "main": "lib/index.js",
  "scripts": {
    "build": "tsc",
    "check": "tsc --noEmit",
    "test:functions": "tsc && node --test \"lib/tests/functions/**/*.test.js\"",
    "test:rules": "tsc && powershell -NoProfile -ExecutionPolicy Bypass -File scripts/run-firestore-rules-tests.ps1",
    "test": "npm run test:functions && npm run test:rules"
  },
  "dependencies": {
    "firebase-admin": "^13.0.0",
    "firebase-functions": "^7.2.5"
  },
  "devDependencies": {
    "@firebase/rules-unit-testing": "^5.0.0",
    "@types/node": "^25.6.0",
    "typescript": "^5.7.0"
  },
  "engines": {
    "node": "22"
  }
}
